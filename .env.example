# ENVIRONMENT
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# PostgreSQL — asyncpg driver required
DATABASE_URL=

# ML Artifacts
MODEL_VERSION=v1

# Inference — predictions below this score are labelled "uncertain"
CONFIDENCE_THRESHOLD=0.7

# App
LOG_LEVEL=INFO
DEBUG=false
